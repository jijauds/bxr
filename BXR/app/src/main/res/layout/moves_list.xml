<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:padding="40dp">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:src="@drawable/ic_back"
        android:tint="#FF6A2A"
        android:layout_alignParentStart="true"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/tvMoveTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Jab"
        android:textColor="#F2F2F2"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="@font/jersey"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMoves"
        android:layout_width="259dp"
        android:layout_height="417dp"
        android:layout_below="@id/tvMoveTitle"
        android:layout_centerInParent="true"
        android:layout_marginTop="40dp"
        android:clipToPadding="false"
        android:paddingStart="60dp"
        android:paddingEnd="60dp" />

    <LinearLayout
        android:id="@+id/layoutDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/recyclerMoves"
        android:layout_marginTop="40dp"
        android:orientation="horizontal"
        android:layout_centerHorizontal="true"
        />

    <Button
        android:id="@+id/btnTrain"
        android:layout_width="232dp"
        android:layout_height="82dp"
        android:layout_below="@id/layoutDots"
        android:layout_marginTop="40dp"
        android:backgroundTint="@color/accent"
        android:lineSpacingExtra="60sp"
        android:text="TRAIN"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        android:typeface="monospace"
        android:layout_centerHorizontal="true"
        />

    <TextView
        android:id="@+id/tvMoveDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvMoveTitle"
        android:layout_centerInParent="true"
        android:layout_marginTop="80dp"
        android:background="#58000000"
        android:clipToPadding="false"
        android:paddingStart="60dp"
        android:paddingEnd="60dp"
        android:text="TextView" />

</RelativeLayout>
