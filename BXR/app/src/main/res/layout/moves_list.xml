<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:padding="40dp">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:src="@drawable/ic_back"
        android:tint="#FF6A2A"
        android:layout_alignParentStart="true"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/tvMoveTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Jab"
        android:textColor="#F2F2F2"
        android:textSize="48sp"
        android:textStyle="bold"
        android:fontFamily="@font/jersey"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMoves"
        android:layout_width="259dp"
        android:layout_height="417dp"
        android:layout_below="@id/tvMoveTitle"
        android:layout_centerInParent="true"
        android:layout_marginTop="40dp"
        android:clipToPadding="false"
        android:paddingStart="0dp"
        android:paddingEnd="0dp" />

    <LinearLayout
        android:id="@+id/layoutDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/recyclerMoves"
        android:layout_marginTop="40dp"
        android:orientation="horizontal"
        android:layout_centerHorizontal="true"
        />

    <Button
        android:id="@+id/btnTrain"
        android:layout_width="161dp"
        android:layout_height="73dp"
        android:layout_below="@id/layoutDots"
        android:layout_alignParentLeft="true"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="29dp"
        android:backgroundTint="@color/accent"
        android:fontFamily="@font/jersey"
        android:lineSpacingExtra="60sp"
        android:text="TRAIN"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        android:typeface="monospace" />

    <Button
        android:id="@+id/btnVid"
        android:layout_width="73dp"
        android:layout_height="73dp"
        android:layout_below="@id/layoutDots"
        android:layout_alignParentLeft="true"
        android:layout_marginLeft="230dp"
        android:layout_marginTop="29dp"
        android:backgroundTint="@color/accent"
        android:fontFamily="@font/jersey"
        android:lineSpacingExtra="60sp"
        android:text="▶"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        android:typeface="monospace" />

    <TextView
        android:id="@+id/tvMoveDescription"
        android:layout_width="191dp"
        android:layout_height="370dp"
        android:layout_below="@id/tvMoveTitle"
        android:layout_centerInParent="true"
        android:layout_marginTop="80dp"
        android:background="@drawable/rounded_corner_view"
        android:clipToPadding="false"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:text="TextView"
        android:textSize="16sp" />

    <VideoView
        android:id="@+id/tvMovePreview"
        android:layout_width="259dp"
        android:layout_height="417dp"
        android:layout_below="@id/tvMoveTitle"
        android:layout_centerInParent="true"
        android:layout_marginTop="87dp"/>


</RelativeLayout>
